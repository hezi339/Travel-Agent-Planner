# 复制为 .env：copy .env.example .env

# 智谱 AI（文本 LLM + Embedding + Vision）
ZHIPU_API_KEY=你的智谱api密钥
ZHIPU_MODEL=glm-5.2
ZHIPU_VISION_MODEL=glm-4v-flash
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_EMBEDDING_DIMENSIONS=1024

# 高德地图（天气经纬度）
GAODE_KEY=你的高德key

# Chroma RAG
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=travel_notes
RAG_TOP_K=3
